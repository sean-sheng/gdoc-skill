#!/usr/bin/env python3
"""Wrapper script for gdoc-fetch CLI"""
import sys
from pathlib import Path

# Add parent directory to path so gdoc_fetch and gdoc_common can be imported
root_dir = Path(__file__).parent.parent.parent
sys.path.insert(0, str(root_dir))

from gdoc_fetch.cli import main

if __name__ == "__main__":
    main()
